{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@rangepilot/config/deepbookPredictTestnet": [
        "packages/config/src/deepbookPredictTestnet.ts"
      ],
      "@rangepilot/config/deepVolTestnet": [
        "packages/config/src/deepVolTestnet.ts"
      ],
      "@rangepilot/config/rangePilotTestnet": [
        "packages/config/src/rangePilotTestnet.ts"
      ],
      "@rangepilot/types/deepbookPredict": [
        "packages/types/src/deepbookPredict.ts"
      ],
      "@rangepilot/types/deepVol": [
        "packages/types/src/deepVol.ts"
      ],
      "@rangepilot/types/rangePilotStrategy": [
        "packages/types/src/rangePilotStrategy.ts"
      ],
      "@rangepilot/sdk/deepbookPredict": [
        "packages/sdk/src/deepbookPredict/index.ts"
      ],
      "@rangepilot/sdk/deepVol": [
        "packages/sdk/src/deepVol/index.ts"
      ],
      "@rangepilot/sdk/rangePilotStrategy": [
        "packages/sdk/src/rangePilotStrategy/index.ts"
      ],
      "@rangepilot/deepvol-trading-react": [
        "packages/deepvol-trading-react/src/index.ts"
      ]
    }
  },
  "include": ["packages/**/*.ts"]
}
